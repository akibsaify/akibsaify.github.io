<!-- SEO: title — use pageTitle if set, else build from frontmatter title, else site name -->
{% set resolvedTitle = pageTitle if pageTitle else (title + " | " + site.name if title else site.name) %}
{% set resolvedDesc = pageDescription if pageDescription else (description if description else site.description) %}
{% set resolvedImage = ogImage if ogImage else "/images/og-default.png" %}
<title>{{ resolvedTitle }}</title>

<!-- Core meta -->
<meta name="description" content="{{ resolvedDesc }}">
<meta name="robots" content="index, follow">
<meta name="googlebot" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">

<!-- Geo & Language targeting for India -->
<meta name="geo.region" content="IN">
<meta name="geo.placename" content="Delhi">
<meta name="language" content="English">
<meta name="author" content="{{ site.author }}">

<!-- Open Graph -->
<meta property="og:type" content="{{ ogType if ogType else 'website' }}">
<meta property="og:title" content="{{ resolvedTitle }}">
<meta property="og:description" content="{{ resolvedDesc }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:image" content="{{ resolvedImage | absoluteUrl(site.url) if resolvedImage.startsWith('/') else resolvedImage }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:locale" content="en_IN">
<meta name="theme-color" content="#6D28D9">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ resolvedTitle }}">
<meta name="twitter:description" content="{{ resolvedDesc }}">
<meta name="twitter:image" content="{{ site.url }}{{ resolvedImage }}">

<!-- Homepage-only: WebSite + Organization schema -->
{% if page.url == "/" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "{{ site.name }}",
      "url": "{{ site.url }}",
      "description": "{{ site.description }}",
      "inLanguage": "en-IN",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ site.url }}/electronics/?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "{{ site.name }}",
      "url": "{{ site.url }}",
      "description": "{{ site.description }}",
      "founder": {
        "@type": "Person",
        "name": "{{ site.author }}",
        "url": "{{ site.instagram }}"
      },
      "sameAs": [
        "{{ site.instagram }}",
        "{{ site.whatsapp }}"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": "{{ site.whatsapp }}",
        "availableLanguage": ["English", "Hindi"]
      }
    },
    {
      "@type": "WebPage",
      "url": "{{ site.url }}/",
      "name": "{{ site.name }} — Best Deals & Offers in India",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".hero__title", ".hero__tagline", ".section-title"]
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is DealDrops?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DealDrops is an Indian deals website that scans Amazon and other stores every few hours to find verified deals with a minimum 30% discount. All prices are compared against the original MRP to show real savings."
          }
        },
        {
          "@type": "Question",
          "name": "How many active deals does DealDrops have?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "DealDrops currently has {{ collections.deals | length }} active verified deals across electronics, fashion, home & kitchen, grocery, and travel categories. Deals are updated every few hours."
          }
        },
        {
          "@type": "Question",
          "name": "Are DealDrops deals verified?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Every deal on DealDrops is automatically verified against the store's current price. We only list deals with a minimum 30% discount from the original MRP, and expired deals are removed automatically."
          }
        }
      ]
    }
  ]
}
</script>
{% endif %}
