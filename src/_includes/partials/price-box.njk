<div class="price-box">
  <div class="price-box__deal-price">{{ dealPrice | priceFormat }}</div>
  {% if originalPrice %}
  <div class="price-box__mrp">MRP: <s>{{ originalPrice | priceFormat }}</s></div>
  {% endif %}
  {% if originalPrice and dealPrice %}
  <div class="price-box__savings">
    🎉 You save {{ originalPrice | savings(dealPrice) }}
    {% if discountPercent %} ({{ discountPercent }}% off){% endif %}
  </div>
  {% endif %}
  <div class="price-box__row">
    <span class="price-box__badge">🏪 {{ store | capitalize }}</span>
    <span class="price-box__badge" style="background:var(--green-soft);color:var(--green);border-color:rgba(0,182,122,0.2);">✅ Verified Deal</span>
  </div>
  <div class="price-box__trust">
    <span>⭐ Handpicked Deal</span>
    <span>🔄 Price Checked Today</span>
    <span>🛡️ Buyer Protected</span>
  </div>
</div>
