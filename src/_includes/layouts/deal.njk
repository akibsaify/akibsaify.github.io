---
layout: layouts/base.njk
---
{% set pageTitle = title + " | Deal Drops — Verified Deal" %}
{% set pageDescription = description %}
{% set ogImage = image if image else "" %}
{% set ogType = "product" %}

{# ── Schema markup (Product + Offer + FAQPage + BreadcrumbList) ── #}
{% set savings = originalPrice - dealPrice if originalPrice > dealPrice else 0 %}
{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "name": "{{ title }}",
      "description": "{{ description }}",
      {% if image %}"image": "{{ site.url }}{{ image }}",{% endif %}
      "brand": {
        "@type": "Brand",
        "name": "{{ store | capitalize }}"
      },
      "offers": {
        "@type": "Offer",
        "url": "{{ site.url }}{{ page.url }}",
        "priceCurrency": "INR",
        "price": "{{ dealPrice }}",
        "availability": "https://schema.org/InStock",
        "seller": {
          "@type": "Organization",
          "name": "{{ store | capitalize }}"
        },
        "itemCondition": "https://schema.org/NewCondition"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the current price of {{ title }}?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The {{ title }} is currently available at ₹{{ dealPrice }} on {{ store | capitalize }}. The original MRP is ₹{{ originalPrice }}, giving you a {{ discountPercent }}% discount and saving ₹{{ savings }}."
          }
        },
        {
          "@type": "Question",
          "name": "Is this deal still active?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This deal was last verified on {{ date | shortDate }}. Prices on {{ store | capitalize }} can change at any time. Click the deal link to check the latest price."
          }
        },
        {
          "@type": "Question",
          "name": "How much can I save on {{ title }}?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "You can save ₹{{ savings }} ({{ discountPercent }}% off) on this product. The deal price is ₹{{ dealPrice }} compared to the MRP of ₹{{ originalPrice }}."
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ site.url }}/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "{{ category | capitalize }}",
          "item": "{{ site.url }}/{{ category }}/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{{ title }}",
          "item": "{{ site.url }}{{ page.url }}"
        }
      ]
    }
  ]
}
</script>
{% endblock %}

<div class="container">
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="breadcrumb__sep">›</span>
    <a href="/{{ category }}/">{{ category | capitalize }}</a>
    <span class="breadcrumb__sep">›</span>
    <span>{{ title }}</span>
  </nav>
</div>

<div class="container">
  <div class="deal-layout">

    <!-- Left: Product Image -->
    <div>
      <div class="deal-image-wrap">
        {% if image %}
        <img src="{{ image }}" alt="{{ title }}" width="400" height="400">
        {% else %}
        <div class="deal-card__placeholder" style="height:100%;font-size:5rem;display:flex;align-items:center;justify-content:center;">
          {% if category == 'electronics' %}📱
          {% elif category == 'fashion' %}👗
          {% elif category == 'home-kitchen' %}🏠
          {% elif category == 'grocery' %}🛒
          {% elif category == 'travel' %}✈️
          {% else %}🏷️{% endif %}
        </div>
        {% endif %}
      </div>
    </div>

    <!-- Right: Deal Info -->
    <div>
      <!-- Tags -->
      <div class="deal-meta__tags">
        <span class="tag tag--store">🏪 {{ store | capitalize }}</span>
        <span class="tag tag--category">{{ category | capitalize }}</span>
        <span class="tag tag--verified">✅ Verified</span>
        {% for t in tags %}
        <span class="tag">{{ t }}</span>
        {% endfor %}
      </div>

      <!-- Title -->
      <h1 class="deal-meta__title">{{ title }}</h1>
      <p class="last-updated">Last checked: {{ date | shortDate }}</p>

      <!-- Price Box -->
      {% include "partials/price-box.njk" %}

      <!-- Coupon Code -->
      {% if couponCode %}
      <div class="coupon-box">
        <div>
          <div class="coupon-box__label">Coupon Code</div>
          <div class="coupon-box__code" id="coupon-code">{{ couponCode }}</div>
        </div>
        <button class="coupon-box__copy" id="copy-coupon-btn" data-code="{{ couponCode }}">
          Copy Code
        </button>
      </div>
      {% endif %}

      <!-- CTA -->
      <a
        class="btn btn--deal"
        href="{{ affiliateLink }}"
        target="_blank"
        rel="nofollow sponsored noopener noreferrer"
        id="main-deal-btn">
        Get This Deal on {{ store | capitalize }} →
      </a>


      <!-- Share Buttons -->
      <div style="margin-top:1.25rem;">
        {% include "partials/share-buttons.njk" %}
      </div>

      <!-- WhatsApp Channel CTA -->
      <div style="margin-top:1.25rem;padding:0.85rem 1rem;background:linear-gradient(135deg,#dcfce7,#d1fae5);border:1.5px solid #86efac;border-radius:var(--radius);text-align:center;">
        <div style="font-size:0.82rem;font-weight:700;color:#166534;">Want deals like this in your pocket?</div>
        <a href="{{ site.whatsapp }}" target="_blank" rel="noopener" style="display:inline-block;margin-top:0.4rem;padding:0.4rem 1rem;background:#25D366;color:#fff;font-size:0.78rem;font-weight:700;border-radius:6px;text-decoration:none;">
          💬 Join WhatsApp Channel
        </a>
      </div>

    </div>
  </div>

  <!-- Deal Content (from markdown body) -->
  <div class="deal-content container--narrow" style="margin-top:2rem;">
    {{ content | safe }}
  </div>

  <!-- How to Claim -->
  <div class="container--narrow" style="margin-top:2rem;margin-bottom:2.5rem;">
    <h2 style="font-size:1.05rem;font-weight:700;color:var(--primary);margin-bottom:1rem;">How to Claim This Deal</h2>
    <div class="steps">
      <div class="step">
        <div class="step__num">1</div>
        <div class="step__text">Click <strong>"Get This Deal"</strong> button above — it opens {{ store | capitalize }} in a new tab.</div>
      </div>
      {% if couponCode %}
      <div class="step">
        <div class="step__num">2</div>
        <div class="step__text">Copy the coupon code <strong>{{ couponCode }}</strong> and paste it at checkout.</div>
      </div>
      <div class="step">
        <div class="step__num">3</div>
        <div class="step__text">Add the product to your cart, apply the code, and complete payment to save {{ discountPercent }}%.</div>
      </div>
      {% else %}
      <div class="step">
        <div class="step__num">2</div>
        <div class="step__text">Add the product to your cart — the discounted price is already applied automatically.</div>
      </div>
      <div class="step">
        <div class="step__num">3</div>
        <div class="step__text">Complete your payment. No coupon code needed — discount is auto-applied.</div>
      </div>
      {% endif %}
    </div>
  </div>

  <!-- FAQ Section -->
  <div class="container--narrow" style="margin-top:2rem;margin-bottom:2rem;">
    <h2 style="font-size:1.05rem;font-weight:700;color:var(--primary);margin-bottom:1rem;">❓ Frequently Asked Questions</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary class="faq-question">What is the current price of {{ title }}?</summary>
        <p class="faq-answer">The {{ title }} is currently available at ₹{{ dealPrice }} on {{ store | capitalize }}. The original MRP is ₹{{ originalPrice }}, giving you a {{ discountPercent }}% discount and saving you ₹{{ savings }}.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-question">Is this deal still active?</summary>
        <p class="faq-answer">This deal was last verified on {{ date | shortDate }}. Prices on {{ store | capitalize }} can change at any time. Click the "Get This Deal" button to check the latest price.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-question">How much can I save on {{ title }}?</summary>
        <p class="faq-answer">You save ₹{{ savings }} ({{ discountPercent }}% off). The deal price is ₹{{ dealPrice }} compared to the MRP of ₹{{ originalPrice }}.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-question">Is this product genuine?</summary>
        <p class="faq-answer">Yes, this product is sold directly through {{ store | capitalize }}. We only list deals from authorized sellers on verified marketplaces.</p>
      </details>
    </div>
  </div>

  <!-- Related Deals -->
  {% set relatedDeals = collections.deals | filterByCategory(category) | exclude(page.url) | limit(4) %}
  {% if relatedDeals.length > 0 %}
  <div style="margin-bottom:2.5rem;">
    <div class="section-header">
      <h2 class="section-title">More {{ category | capitalize }} Deals</h2>
      <a href="/{{ category }}/" class="view-all">View all →</a>
    </div>
    <div class="deals-grid">
      {% for dealItem in relatedDeals %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>

<!-- Sticky CTA (mobile) -->
<div class="sticky-cta" id="sticky-cta">
  <div class="sticky-cta__price">
    <div class="price">{{ dealPrice | priceFormat }}</div>
    {% if originalPrice %}<div class="mrp">MRP {{ originalPrice | priceFormat }}</div>{% endif %}
  </div>
  <a
    class="btn btn--deal"
    href="{{ affiliateLink }}"
    target="_blank"
    rel="nofollow sponsored noopener noreferrer">
    Get Deal →
  </a>
</div>

{% block scripts %}
<script>
  // Hide sticky CTA when main button is visible (mobile only)
  const mainBtn = document.getElementById('main-deal-btn');
  const stickyCta = document.getElementById('sticky-cta');
  if (mainBtn && stickyCta && window.innerWidth < 600) {
    const obs = new IntersectionObserver(entries => {
      stickyCta.style.display = entries[0].isIntersecting ? 'none' : 'flex';
    }, { threshold: 0 });
    obs.observe(mainBtn);
  }
</script>
{% endblock %}
