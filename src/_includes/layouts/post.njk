---
layout: layouts/base.njk
---
{% set pageTitle = title + " | Deal Drops" %}
{% set pageDescription = description %}
{% set ogImage = image if image else "" %}

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "{{ title }}",
      "description": "{{ description }}",
      "datePublished": "{{ date | isoDate }}",
      "dateModified": "{{ date | isoDate }}",
      "mainEntityOfPage": "{{ site.url }}{{ page.url }}",
      "author": {
        "@type": "Person",
        "name": "{{ site.author }}"
      },
      "publisher": {
        "@type": "Organization",
        "name": "{{ site.name }}",
        "url": "{{ site.url }}"
      },
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".post-body h2", ".post-body p:first-of-type", ".post-body table"]
      },
      "isAccessibleForFree": true,
      "inLanguage": "en-IN",
      "about": {
        "@type": "Thing",
        "name": "{{ title }}"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are the best {{ category if category else 'product' }} deals right now in {{ site.currentMonth }}?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{ description }}"
          }
        },
        {
          "@type": "Question",
          "name": "Are these deals verified?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Every deal listed on DealDrops is verified daily. We only feature products with a minimum 30% discount from the original MRP. Prices are checked against the store every few hours."
          }
        },
        {
          "@type": "Question",
          "name": "How often are these deals updated?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "This guide is updated regularly with the latest prices and new product drops. Deals are verified every few hours — last updated {{ date | shortDate }}."
          }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "{{ site.url }}/"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Buying Guides",
          "item": "{{ site.url }}/blog/"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "name": "{{ title }}",
          "item": "{{ site.url }}{{ page.url }}"
        }
      ]
    }
  ]
}
</script>
{% endblock %}

<!-- Blog Hero -->
<div class="blog-hero">
  <div class="container container--narrow">
    <nav class="breadcrumb" style="color:rgba(255,255,255,0.6);padding:0 0 0.75rem;">
      <a href="/" style="color:rgba(255,255,255,0.7);">Home</a>
      <span class="breadcrumb__sep">›</span>
      <a href="/blog/" style="color:rgba(255,255,255,0.7);">Blog</a>
      <span class="breadcrumb__sep">›</span>
      <span style="color:#fff;">{{ title }}</span>
    </nav>
    <div class="blog-hero__label">{{ category | capitalize if category else "Guide" }} · {{ date | shortDate }}</div>
    <h1 class="blog-hero__title">{{ title }}</h1>
    <p class="blog-hero__meta">By {{ site.author }} · {{ readTime if readTime else "5" }} min read</p>
  </div>
</div>

<div class="container container--narrow" style="padding-top:2rem;padding-bottom:3rem;">

  <!-- Table of Contents -->
  {% if toc %}
  <div class="toc">
    <div class="toc__title">📑 Table of Contents</div>
    <nav class="toc__list">
      {% for item in toc %}
      <a href="#{{ item.id }}">{{ item.text }}</a>
      {% endfor %}
    </nav>
  </div>
  {% endif %}

  <!-- Ad: Above Article -->
  <div style="margin-bottom:1.5rem;text-align:center;">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-6478161332276600"
         data-ad-slot="auto"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- Article body -->
  <article class="post-body">
    {{ content | safe }}
  </article>

  <!-- Ad: After Article -->
  <div style="margin-top:2rem;text-align:center;">
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="ca-pub-6478161332276600"
         data-ad-slot="auto"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  <!-- Share -->
  <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border);">
    {% set title = title %}
    {% include "partials/share-buttons.njk" %}
  </div>

  <!-- Related posts -->
  {% set relatedPosts = collections.blog | exclude(page.url) | limit(3) %}
  {% if relatedPosts.length > 0 %}
  <div style="margin-top:2.5rem;">
    <h2 style="font-size:1rem;font-weight:700;color:var(--primary);margin-bottom:1rem;">More Guides</h2>
    <div style="display:flex;flex-direction:column;gap:0.75rem;">
      {% for post in relatedPosts %}
      <a href="{{ post.url }}" style="display:flex;gap:0.75rem;background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:1rem;align-items:flex-start;">
        <div style="flex:1;">
          <div style="font-size:0.72rem;color:var(--text-muted);margin-bottom:0.25rem;">{{ post.date | shortDate }}</div>
          <div style="font-size:0.92rem;font-weight:700;color:var(--text);">{{ post.data.title }}</div>
        </div>
        <span style="color:var(--accent);font-size:0.9rem;">→</span>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

</div>
