---
layout: layouts/base.njk
pageTitle: "Deal Drops — Best Deals, Coupons & Offers on Amazon, Flipkart India (2026)"
pageDescription: "Save up to 80% with verified deals and coupon codes on Amazon, Flipkart, Myntra & more. Handpicked daily by our team — join 10,000+ deal hunters on WhatsApp."
---

<!-- Hero -->
<section class="hero">
  <div class="container">
    <div class="hero__eyebrow">🔥 Updated Every Few Hours · {{ site.currentMonth }}</div>
    <h1 class="hero__title">India's Smartest<br><span>Deal Finder</span></h1>
    <p class="hero__tagline">We scan Amazon & Flipkart every day so you never miss a deal. {{ collections.deals | length }}+ verified offers, updated daily.</p>
    <div class="hero__cta-group">
      <a href="#today-deals" class="btn btn--primary">Today's Top Deals ↓</a>
      <a href="{{ site.whatsapp }}" target="_blank" rel="noopener" class="btn btn--secondary">💬 WhatsApp Alerts</a>
    </div>
    <div class="hero__stats">
      <div class="hero__stat">
        <strong>{{ collections.deals | length }}+</strong>
        <span>Active Deals</span>
      </div>
      <div class="hero__stat">
        <strong>{{ stores | length }}</strong>
        <span>Stores</span>
      </div>
      <div class="hero__stat">
        <strong>100%</strong>
        <span>Verified</span>
      </div>
      <div class="hero__stat">
        <strong>24/7</strong>
        <span>Auto-Updated</span>
      </div>
    </div>
  </div>
</section>

<!-- How It Works -->
<section class="section section--white">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">How It Works</h2>
    </div>
    <div class="how-it-works">
      <div class="how-step">
        <div class="how-step__icon">🤖</div>
        <h3>Bot Scans Prices 24/7</h3>
        <p>Our automated bot monitors thousands of products on Amazon India every few hours to catch the biggest price drops.</p>
      </div>
      <div class="how-step">
        <div class="how-step__icon">✅</div>
        <h3>Only 30%+ Discounts</h3>
        <p>We only list deals with a minimum 30% real discount — no fake markups, no expired offers, no inflated MRPs.</p>
      </div>
      <div class="how-step">
        <div class="how-step__icon">🚀</div>
        <h3>You Save Instantly</h3>
        <p>Click any deal to go directly to the store and buy at the lowest verified price. Simple as that.</p>
      </div>
    </div>
  </div>
</section>

<!-- Category Quick Links -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Browse by Category</h2>
      <a href="/electronics/" class="view-all">All categories →</a>
    </div>
    <div class="cat-grid">
      {% for cat in categories %}
      <a href="/{{ cat.slug }}/" class="cat-card">
        <span class="cat-card__emoji">{{ cat.emoji }}</span>
        <div>
          <div class="cat-card__name">{{ cat.name }}</div>
          <div class="cat-card__sub">
            {{ collections.deals | filterByCategory(cat.slug) | length }} active deals
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Today's Top Deals (High Value) -->
<section class="section section--white" id="today-deals">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Today's Top Deals <span>HOT</span></h2>
      <a href="/electronics/" class="view-all">View all →</a>
    </div>
    <div class="deals-grid">
      {% for dealItem in collections.highValueDeals | limit(8) %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Shop by Store -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Shop by Store</h2>
      <a href="/stores/" class="view-all">All stores →</a>
    </div>
    <div class="store-grid">
      {% for store in stores %}
      <a href="/store/{{ store.slug }}/" class="store-badge" style="border-color:{{ store.color }}20;">
        <span class="store-badge__dot" style="background:{{ store.color }};"></span>
        {{ store.name }}
        <span class="store-badge__count">{{ collections.deals | filterByStore(store.slug) | length }}</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Electronics Deals -->
{% set electronicsDeals = collections.deals | filterByCategory('electronics') | limit(4) %}
{% if electronicsDeals.length > 0 %}
<section class="section section--white">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">📱 Electronics Deals</h2>
      <a href="/electronics/" class="view-all">View all →</a>
    </div>
    <div class="deals-grid">
      {% for dealItem in electronicsDeals %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Fashion Deals -->
{% set fashionDeals = collections.deals | filterByCategory('fashion') | limit(4) %}
{% if fashionDeals.length > 0 %}
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">👗 Fashion Deals</h2>
      <a href="/fashion/" class="view-all">View all →</a>
    </div>
    <div class="deals-grid">
      {% for dealItem in fashionDeals %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Home & Kitchen Deals -->
{% set homeDeals = collections.deals | filterByCategory('home-kitchen') | limit(4) %}
{% if homeDeals.length > 0 %}
<section class="section section--white">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">🏠 Home & Kitchen Deals</h2>
      <a href="/home-kitchen/" class="view-all">View all →</a>
    </div>
    <div class="deals-grid">
      {% for dealItem in homeDeals %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Latest Deals (newest across all categories) -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">🕐 Just Added <span>NEW</span></h2>
    </div>
    <div class="deals-grid">
      {% for dealItem in collections.allDeals | limit(4) %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Social CTAs -->
<section class="section section--white">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Never Miss a Deal</h2>
    </div>
    <div class="social-ctas">
      <div class="social-card social-card--wa">
        <div class="social-card__icon">💬</div>
        <div class="social-card__text">
          <h3>Daily Deal Drops on WhatsApp</h3>
          <p>Join 10,000+ deal hunters getting instant alerts on the hottest Amazon & Flipkart deals.</p>
          <a href="{{ site.whatsapp }}" target="_blank" rel="noopener" class="btn btn--sm">Join Channel →</a>
        </div>
      </div>
      <div class="social-card social-card--ig">
        <div class="social-card__icon">📸</div>
        <div class="social-card__text">
          <h3>Follow on Instagram</h3>
          <p>@akibonline — daily deal roundups, unboxings and money-saving tips.</p>
          <a href="{{ site.instagram }}" target="_blank" rel="noopener" class="btn btn--sm">@akibonline →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Buying Guides / Blog -->
{% set blogPosts = collections.blog | limit(3) %}
{% if blogPosts.length > 0 %}
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">📝 Buying Guides</h2>
      <a href="/guides/" class="view-all">All guides →</a>
    </div>
    <div class="blog-grid">
      {% for post in blogPosts %}
      <a href="{{ post.url }}" class="blog-card">
        <div class="blog-card__meta">{{ post.date | shortDate }}</div>
        <h3 class="blog-card__title">{{ post.data.title }}</h3>
        {% if post.data.description %}
        <p class="blog-card__desc">{{ post.data.description }}</p>
        {% endif %}
        <span class="blog-card__link">Read guide →</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- FAQ Section (visible, matches schema in seo-head) -->
<section class="section section--white">
  <div class="container container--narrow">
    <div class="section-header">
      <h2 class="section-title">Frequently Asked Questions</h2>
    </div>
    <div class="faq-list">
      <details class="faq-item" open>
        <summary class="faq-item__q">What is DealDrops?</summary>
        <div class="faq-item__a">DealDrops is an Indian deals website that scans Amazon and other stores every few hours to find verified deals with a minimum 30% discount. All prices are compared against the original MRP to show real savings.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-item__q">How many active deals does DealDrops have?</summary>
        <div class="faq-item__a">DealDrops currently has {{ collections.deals | length }}+ active verified deals across electronics, fashion, home & kitchen, grocery, and travel categories. Deals are updated every few hours by our automated bot.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-item__q">Are DealDrops deals verified?</summary>
        <div class="faq-item__a">Yes. Every deal is automatically verified against the store's current price. We only list deals with a minimum 30% discount from the original MRP, and expired deals are removed automatically.</div>
      </details>
      <details class="faq-item">
        <summary class="faq-item__q">Does DealDrops cost anything?</summary>
        <div class="faq-item__a">No. DealDrops is 100% free to use. We earn a small affiliate commission when you buy through our links, at no extra cost to you.</div>
      </details>
    </div>
  </div>
</section>
