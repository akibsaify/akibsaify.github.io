---
layout: layouts/base.njk
pageTitle: "Deal Drops — Best Deals, Coupons & Offers on Amazon, Flipkart India (2026)"
pageDescription: "Save up to 80% with verified deals and coupon codes on Amazon, Flipkart, Myntra & more. Handpicked daily by our team — join 10,000+ deal hunters on WhatsApp."
---

<!-- Hero -->
<section class="hero">
  <div class="container">
    <div class="hero__eyebrow">🔥 Updated Daily</div>
    <h1 class="hero__title">Deal<span>Drops</span></h1>
    <p class="hero__tagline">Verified Deals. Real Savings. Every Day.</p>
    <div class="hero__cta-group">
      <a href="#today-deals" class="btn btn--primary">Today's Deals ↓</a>
      <a href="{{ site.whatsapp }}" target="_blank" rel="noopener" class="btn btn--secondary">💬 WhatsApp Alerts</a>
    </div>
    <div class="hero__stats">
      <div class="hero__stat">
        <strong>500+</strong>
        <span>Active Deals</span>
      </div>
      <div class="hero__stat">
        <strong>100%</strong>
        <span>Verified</span>
      </div>
      <div class="hero__stat">
        <strong>Daily</strong>
        <span>Updates</span>
      </div>
    </div>
  </div>
</section>

<!-- Category Quick Links -->
<section class="section section--white">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Browse by Category</h2>
    </div>
    <div class="cat-grid">
      {% for cat in categories %}
      <a href="/{{ cat.slug }}/" class="cat-card">
        <span class="cat-card__emoji">{{ cat.emoji }}</span>
        <div>
          <div class="cat-card__name">{{ cat.name }}</div>
          <div class="cat-card__sub">
            {{ collections.deals | filterByCategory(cat.slug) | length }} deals
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Today's Top Deals -->
<section class="section" id="today-deals">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Today's Top Deals <span>HOT</span></h2>
      <a href="/electronics/" class="view-all">View all</a>
    </div>
    <div class="deals-grid">
      {% for dealItem in collections.deals | limit(8) %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>

<!-- Store Quick Links -->
<section class="section section--white">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Shop by Store</h2>
    </div>
    <div class="store-grid">
      {% for store in stores %}
      <a href="/store/{{ store.slug }}/" class="store-badge" style="border-color:{{ store.color }}20;">
        <span class="store-badge__dot" style="background:{{ store.color }};"></span>
        {{ store.name }}
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Electronics Deals -->
{% set electronicsDeals = collections.deals | filterByCategory('electronics') | limit(4) %}
{% if electronicsDeals.length > 0 %}
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">📱 Electronics Deals</h2>
      <a href="/electronics/" class="view-all">View all →</a>
    </div>
    <div class="deals-grid">
      {% for dealItem in electronicsDeals %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Fashion Deals -->
{% set fashionDeals = collections.deals | filterByCategory('fashion') | limit(4) %}
{% if fashionDeals.length > 0 %}
<section class="section section--white">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">👗 Fashion Deals</h2>
      <a href="/fashion/" class="view-all">View all →</a>
    </div>
    <div class="deals-grid">
      {% for dealItem in fashionDeals %}
        {% set deal = dealItem %}
        {% include "partials/deal-card.njk" %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Social CTAs -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Get Deals Instantly</h2>
    </div>
    <div class="social-ctas">
      <div class="social-card social-card--wa">
        <div class="social-card__icon">💬</div>
        <div class="social-card__text">
          <h3>Daily Deal Drops on WhatsApp</h3>
          <p>Join 10,000+ deal hunters getting instant alerts on Amazon & Flipkart deals.</p>
          <a href="{{ site.whatsapp }}" target="_blank" rel="noopener" class="btn btn--sm">Join Channel →</a>
        </div>
      </div>
      <div class="social-card social-card--ig">
        <div class="social-card__icon">📸</div>
        <div class="social-card__text">
          <h3>Follow on Instagram</h3>
          <p>@akibonline — daily deal posts, unboxings and money-saving tips.</p>
          <a href="{{ site.instagram }}" target="_blank" rel="noopener" class="btn btn--sm">@akibonline →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Latest Blog Posts -->
{% set blogPosts = collections.blog | limit(3) %}
{% if blogPosts.length > 0 %}
<section class="section section--white">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">📝 Buying Guides</h2>
      <a href="/blog/" class="view-all">View all →</a>
    </div>
    <div style="display:flex;flex-direction:column;gap:0.75rem;">
      {% for post in blogPosts %}
      <a href="{{ post.url }}" style="display:flex;gap:0.75rem;background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:1rem;align-items:center;">
        <div style="flex:1;">
          <div style="font-size:0.72rem;color:var(--text-muted);margin-bottom:0.2rem;">{{ post.date | shortDate }}</div>
          <div style="font-size:0.92rem;font-weight:700;color:var(--text);">{{ post.data.title }}</div>
        </div>
        <span style="color:var(--accent);font-size:1rem;font-weight:700;">→</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
